# Ignition runtime data — all auto-generated, never commit
# We selectively un-ignore the WebDev integration test scripts
ignition/data/*
!ignition/data/projects/
ignition/data/projects/*
!ignition/data/projects/TestFactry/
ignition/data/projects/TestFactry/*
!ignition/data/projects/TestFactry/com.inductiveautomation.webdev/

# Ignition module binaries are build artifacts
ignition/user-lib/

